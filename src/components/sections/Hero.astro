---
import GraphFigure from '../GraphFigure.astro';
---

<section class="section section--first hero" aria-labelledby="hero-heading">
  <div class="container hero__grid">
    <div class="hero__copy">
      <span class="section-label reveal reveal-1">
        ASTAR AUDIT · Smart Contract Security
      </span>

      <h1 id="hero-heading" class="hero__title">
        <span class="hero__line reveal reveal-2">We audit the math,</span>
        <span class="hero__line reveal reveal-3">
          not <em>just</em> the code.
        </span>
      </h1>

      <p class="lede reveal reveal-4">
        Smart contract security for DeFi math primitives —
        AMM, bonding curves, lending protocols, and CDP systems.
      </p>

      <div class="hero__cta reveal reveal-5">
        <a href="#problem" class="hero__more">
          <span>How we work</span>
          <svg viewBox="0 0 24 16" width="22" height="14" aria-hidden="true">
            <line x1="0" y1="8" x2="20" y2="8" stroke="currentColor" stroke-width="1"/>
            <path d="M16 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1"/>
          </svg>
        </a>
      </div>

      <!-- A small "abstract" — a one-line intellectual statement
           that mirrors a journal abstract, set in italic body type. -->
      <p class="hero__abstract reveal reveal-5">
        <span class="hero__abstract-mark">¶</span>
        <em>
          Vulnerabilities in DeFi don't always look like bugs. They look like
          rounding errors, broken invariants, and edge cases at the boundary
          of the protocol's own mathematics.
        </em>
      </p>
    </div>

    <aside class="hero__figure reveal reveal-3">
      <GraphFigure />
      <figcaption class="hero__caption">
        <span class="hero__caption-tag">Fig. 1.1</span>
        <span class="hero__caption-text">
          Optimal path from source <em>s</em> to target <em>t</em>; dashed
          edges denote alternative explored paths.
        </span>
      </figcaption>
    </aside>
  </div>

  <!-- Footer ribbon — three small "stats" set as text in mathematical
       paper style; an honest claim, not a marketing carousel. -->
  <div class="container hero__ribbon reveal reveal-5">
    <dl>
      <div>
        <dt>Domain</dt>
        <dd>DeFi math primitives</dd>
      </div>
      <div>
        <dt>Method</dt>
        <dd>First-principles review</dd>
      </div>
      <div>
        <dt>Response</dt>
        <dd>≤ 24 hours</dd>
      </div>
    </dl>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 6vw, 5rem);
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: center;
  }

  .hero__title {
    margin-top: 0.4rem;
    margin-bottom: 1.4rem;
  }

  .hero__line {
    display: block;
  }

  .hero__line:nth-child(2) {
    text-indent: 1.6em;
    color: var(--color-ink);
  }

  .hero__line em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-accent);
  }

  .hero__cta {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .hero__more {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  .hero__more:hover { color: var(--color-accent-2); }

  .hero__more svg {
    transition: transform 0.22s var(--ease-out);
  }

  .hero__more:hover svg { transform: translateX(4px); }

  .hero__abstract {
    margin-top: 2.4rem;
    max-width: 52ch;
    padding-left: 1.1rem;
    border-left: 1px solid var(--color-rule-strong);
    color: var(--color-ink-3);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .hero__abstract-mark {
    font-family: var(--font-display);
    color: var(--color-accent);
    margin-right: 0.4em;
    font-style: normal;
  }

  .hero__figure {
    width: 100%;
    max-width: 540px;
    justify-self: end;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .hero__caption {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    font-family: var(--font-body);
    font-style: italic;
    color: var(--color-ink-3);
    font-size: 0.88rem;
    line-height: 1.45;
    padding: 0 0.25rem;
  }

  .hero__caption-tag {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
    flex-shrink: 0;
  }

  .hero__caption em { color: var(--color-ink-2); }

  /* ----- Footer ribbon ----- */
  .hero__ribbon {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
  }

  .hero__ribbon dl {
    margin: 0;
    padding-top: 1.4rem;
    border-top: 1px solid var(--color-ink);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: start;
    gap: 1rem 1.6rem;
  }

  .hero__ribbon dl > div {
    min-width: 0;
    padding-right: 1rem;
    border-right: 1px solid var(--color-rule);
  }

  .hero__ribbon dl > div:last-child { border-right: 0; }

  .hero__ribbon dt {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin-bottom: 0.35rem;
  }

  .hero__ribbon dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-ink);
    font-style: italic;
    line-height: 1.3;
  }

  @media (max-width: 880px) {
    .hero__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero__figure { justify-self: start; max-width: 480px; }
    .hero__line:nth-child(2) { text-indent: 0.8em; }
  }

  @media (max-width: 540px) {
    .hero__ribbon dl { grid-template-columns: 1fr; gap: 1.1rem; }
    .hero__ribbon dl > div {
      border-right: 0;
      border-top: 1px solid var(--color-rule);
      padding-top: 1rem;
      padding-right: 0;
    }
    .hero__ribbon dl > div:first-child { border-top: 0; padding-top: 0; }
  }

  @media (max-width: 480px) {
    .hero__line:nth-child(2) { text-indent: 0; }
  }
</style>
