---
---

<section id="contact" class="section contact" aria-labelledby="contact-heading">
  <div class="container contact__grid">
    <div class="contact__head">
      <span class="section-label">§ 04 · Contact</span>
      <h2 id="contact-heading">
        Tell us about <em>your project</em>
      </h2>
      <p class="contact__intro">
        Interested in an audit? Reach out with a brief description of your
        protocol, the codebase scope, and your timeline. We'll respond within
        24 hours.
      </p>

      <dl class="contact__meta">
        <div class="contact__meta-email">
          <dt>Email</dt>
          <dd>
            <a href="mailto:contact@astaraudit.com">contact@astaraudit.com</a>
          </dd>
        </div>
        <div class="contact__meta-secondary">
          <div>
            <dt>Response time</dt>
            <dd><em>≤ 24 hours</em></dd>
          </div>
          <div>
            <dt>Engagement</dt>
            <dd><em>Security Review</em></dd>
          </div>
        </div>
      </dl>
    </div>

    <form class="contact__form" id="audit-inquiry-form" novalidate>
      <header class="contact__form-head">
        <span class="contact__form-tag">Form 4.1</span>
        <span class="contact__form-name">Audit inquiry</span>
      </header>

      <div class="field">
        <label for="contact-name">Name</label>
        <input id="contact-name" name="name" type="text" required autocomplete="name" />
      </div>

      <div class="field">
        <label for="contact-email">Email</label>
        <input id="contact-email" name="email" type="email" required autocomplete="email" />
      </div>

      <div class="field">
        <label for="contact-protocol">
          Protocol name <span class="optional">— optional</span>
        </label>
        <input id="contact-protocol" name="protocol" type="text" autocomplete="organization" />
      </div>

      <div class="field">
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows="5" required></textarea>
      </div>

      <div class="contact__actions">
        <button type="submit" class="btn">
          <span>Send inquiry</span>
          <svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.4"/>
          </svg>
        </button>
        <p class="contact__note">
          Opens your email client with the message pre-filled.
        </p>
      </div>
    </form>
  </div>
</section>

<script is:inline>
  // ============================================================
  // Contact form — mailto fallback.
  // TODO: replace this client-only handler with a real form
  // backend (Formspree / serverless function / API route) when
  // the team is ready. Until then, submitting the form opens
  // the visitor's default mail client with the inquiry pre-filled.
  // ============================================================
  (function () {
    var form = document.getElementById('audit-inquiry-form');
    if (!form) return;

    form.addEventListener('submit', function (event) {
      event.preventDefault();

      var data = new FormData(form);
      var name = String(data.get('name') || '').trim();
      var email = String(data.get('email') || '').trim();
      var protocol = String(data.get('protocol') || '').trim();
      var message = String(data.get('message') || '').trim();

      if (!name || !email || !message) {
        form.reportValidity();
        return;
      }

      var subject = 'Audit Inquiry — ' + (protocol || 'Untitled protocol');

      var body = [
        'Name: ' + name,
        'Email: ' + email,
        'Protocol: ' + (protocol || '—'),
        '',
        'Message:',
        message,
      ].join('\n');

      var href =
        'mailto:contact@astaraudit.com' +
        '?subject=' + encodeURIComponent(subject) +
        '&body=' + encodeURIComponent(body);

      window.location.href = href;
    });
  })();
</script>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .contact__head h2 { margin-top: 0.4rem; }
  .contact__head h2 em {
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
  }

  .contact__intro {
    color: var(--color-ink-2);
    font-size: 1.08rem;
    line-height: 1.7;
    max-width: 46ch;
  }

  .contact__meta {
    margin: 2.5rem 0 0;
    padding: 1.4rem 0 0;
    border-top: 1px solid var(--color-ink);
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .contact__meta-email {
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--color-rule);
    text-align: center;
  }

  .contact__meta-secondary {
    display: flex;
    gap: 1.2rem;
  }

  .contact__meta-secondary > div {
    flex: 1;
    min-width: 0;
    padding-right: 0.9rem;
    border-right: 1px solid var(--color-rule);
  }

  .contact__meta-secondary > div:last-child {
    padding-right: 0;
    border-right: 0;
  }

  .contact__meta dt {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-3);
    margin-bottom: 0.35rem;
    white-space: nowrap;
  }

  .contact__meta dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-ink);
    line-height: 1.35;
    white-space: nowrap;
  }

  .contact__meta dd em { color: var(--color-ink); font-style: italic; }
  .contact__meta a { color: var(--color-ink); }

  .contact__form {
    display: grid;
    gap: 1.6rem;
    background: var(--color-bg-alt);
    padding: clamp(1.6rem, 3vw, 2.6rem);
    border: 1px solid var(--color-ink);
    position: relative;
  }

  .contact__form-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 1.1rem;
    margin-bottom: 0.2rem;
    border-bottom: 1px solid var(--color-rule-strong);
  }

  .contact__form-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }

  .contact__form-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-ink);
  }

  .optional {
    font-family: var(--font-body);
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    font-size: 0.78rem;
    color: var(--color-ink-3);
    margin-left: 0.4em;
  }

  .contact__actions {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    flex-wrap: wrap;
    margin-top: 0.4rem;
  }

  .contact__note {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--color-ink-3);
    max-width: 24ch;
    line-height: 1.45;
  }

  @media (max-width: 400px) {
    .contact__meta-secondary {
      flex-direction: column;
      gap: 1rem;
    }
    .contact__meta-secondary > div {
      border-right: 0;
      padding-right: 0;
    }
  }

  @media (max-width: 880px) {
    .contact__grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
