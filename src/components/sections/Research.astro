---
import { research } from '../../data/research';
---

<section id="research" class="section research" aria-labelledby="research-heading">
  <div class="container">
    <header class="research__head">
      <div class="research__head-row">
        <div>
          <span class="section-label">§ 03 · Research</span>
          <h2 id="research-heading">Research</h2>
        </div>
        <p class="lede research__lede">
          Published security analysis from the <strong class="brand">A<sup class="star">∗</sup> Audit</strong> team.
        </p>
      </div>
    </header>

    <ul class="research__grid" role="list">
      {research.map((item) => {
        const isExternal = item.url.startsWith('http');
        return (
          <li class="entry">
            <a
              class="entry__link"
              href={item.url}
              {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              <div class="entry__meta">
                <span class="entry__tag">{item.tag}</span>
                <span class="entry__sep" aria-hidden="true">·</span>
                <span class="entry__type">{item.type}</span>
              </div>

              <h3 class="entry__title">{item.title}</h3>
              <p class="entry__desc">{item.summary}</p>

              <div class="entry__foot">
                <span class="entry__date">{item.date}</span>
                <span class="entry__cta" aria-hidden="true">
                  Read
                  <svg viewBox="0 0 16 16" width="13" height="13">
                    <path d="M3 8h10M9 4l4 4-4 4" fill="none"
                          stroke="currentColor" stroke-width="1.2"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .research__head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .research__head-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--color-ink);
    padding-bottom: 1.6rem;
  }

  .research__head h2 { margin: 0; }
  .research__lede {
    margin: 0;
    max-width: none;
    text-align: right;
    font-size: clamp(0.92rem, 1.1vw, 1.02rem);
    white-space: nowrap;
  }
  .research__lede .brand { font-weight: 600; font-style: normal; color: var(--color-ink); }
  .research__lede .star {
    color: var(--color-accent);
    display: inline-block;
    font-size: 0.65em;
    vertical-align: baseline;
    line-height: 1;
    transform: translateY(-0.65em);
    margin-left: 0.05em;
  }

  .research__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  .entry {
    border-right: 1px solid var(--color-rule);
    transition: background 0.25s var(--ease-out);
  }

  .entry:last-child { border-right: 0; }
  .entry:hover { background: var(--color-bg-alt); }

  .entry__link {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: 2rem clamp(1.4rem, 2vw, 1.8rem);
    height: 100%;
    text-decoration: none;
    color: var(--color-ink);
    position: relative;
  }

  /* A subtle hover progress bar — the chosen path drawing in. */
  .entry__link::after {
    content: '';
    position: absolute;
    left: 0; right: 100%;
    top: 0;
    height: 2px;
    background: var(--color-accent);
    transition: right 0.4s var(--ease-out);
  }

  .entry:hover .entry__link::after { right: 0; }

  .entry__meta {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }

  .entry__tag { color: var(--color-accent); font-weight: 500; }
  .entry__sep { color: var(--color-ink-3); }

  .entry__title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.45rem;
    line-height: 1.22;
    color: var(--color-ink);
    margin: 0;
    text-wrap: pretty;
  }

  .entry__desc {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 0.98rem;
    line-height: 1.55;
    font-style: italic;
    flex: 1;
  }

  .entry__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--color-rule);
  }

  .entry__date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--color-ink-3);
  }

  .entry__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-2);
  }

  .entry:hover .entry__cta {
    color: var(--color-accent);
  }

  .entry:hover .entry__cta svg {
    transform: translateX(3px);
    transition: transform 0.22s var(--ease-out);
  }

  @media (max-width: 880px) {
    .research__head-row { flex-direction: column; align-items: flex-start; }
    .research__lede { text-align: left; white-space: normal; }
    .research__grid { grid-template-columns: 1fr; }
    .entry { border-right: 0; border-bottom: 1px solid var(--color-rule); }
    .entry:last-child { border-bottom: 0; }
  }
</style>
