---
const steps = [
  {
    index: 'i.',
    label: 'Identify',
    style: 'Definition',
    question: 'What invariant must hold?',
    description:
      'We define the mathematical properties the protocol depends on — the equations, bounds, and relationships that must remain true for the system to be solvent and fair.',
  },
  {
    index: 'ii.',
    label: 'Analyze',
    style: 'Theorem',
    question: 'Does this state transition preserve it?',
    description:
      'We trace every code path that modifies state and verify it maintains the invariant. Rounding direction, precision loss, boundary conditions, and ordering dependencies are all examined.',
  },
  {
    index: 'iii.',
    label: 'Break',
    style: 'Counter-example',
    question: 'What inputs or call sequences could violate it?',
    description:
      'We construct concrete attack scenarios — specific parameter values, transaction orderings, and multi-step exploit paths that would break the invariant.',
  },
];
---

<section id="methodology" class="section methodology" aria-labelledby="methodology-heading">
  <div class="container">
    <header class="methodology__head">
      <span class="section-label">§ 02 · Methodology</span>
      <h2 id="methodology-heading">
        Three questions. <em>Every function.</em> Every path.
      </h2>
      <p class="lede">
        Our audit process starts from first principles, not from a checklist.
        For every state-changing function, we ask three questions:
      </p>

      <!-- Centered display equation, set as a numbered AMS-style line. -->
      <div class="equation" aria-hidden="true">
        <span><em>I</em>(<em>s</em>) ⟹ <em>I</em>(<em>s</em>′)</span>
        <span class="equation__tag">(2.1)</span>
      </div>
      <p class="methodology__caption">
        <em>If the invariant holds before a transaction, it must still hold after.</em>
      </p>
    </header>

    <ol class="methodology__grid" role="list">
      {steps.map((step) => (
        <li>
          <article class="theorem">
            <header class="theorem__head">
              <span class="theorem__num">Step {step.index}</span>
              <span class="theorem__name">{step.style}</span>
            </header>

            <h3 class="theorem__label">{step.label}</h3>

            <p class="theorem__question">
              <em>{step.question}</em>
            </p>

            <p class="theorem__desc">{step.description}</p>

            <span class="theorem__qed" aria-hidden="true">∎</span>
          </article>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .methodology__head {
    max-width: 820px;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .methodology__head h2 em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-accent);
    font-weight: 400;
  }

  .methodology__caption {
    text-align: center;
    margin: 0 auto 0;
    max-width: 60ch;
    color: var(--color-ink-3);
    font-size: 0.92rem;
  }

  .methodology__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .methodology__grid > li { display: contents; }

  .theorem__label {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.7rem;
    color: var(--color-ink);
    margin: 0;
    line-height: 1;
  }

  .theorem__question {
    margin: 0;
    font-family: var(--font-body);
    font-style: italic;
    color: var(--color-ink);
    font-size: 1.1rem;
    line-height: 1.45;
  }

  .theorem__desc {
    margin: 0;
    color: var(--color-ink-2);
    font-size: 0.98rem;
    line-height: 1.65;
    flex: 1;
  }

  @media (max-width: 880px) {
    .methodology__grid { grid-template-columns: 1fr; }
  }
</style>
